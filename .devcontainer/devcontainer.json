{
  "name": "CSCI 2020 Database Environment",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "db",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5432],
  "portsAttributes": {
    "5432": { "label": "PostgreSQL" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "sqltools.connections": [
          {
            "name": "CSCI 2020 Local DB",
            "driver": "PostgreSQL",
            "server": "localhost",
            "port": 5432,
            "database": "csci2020",
            "username": "admin",
            "password": "admin",
            "previewLimit": 50,
            "savePassword": true
          }
        ]
      }
    }
  }
}